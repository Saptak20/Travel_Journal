<%- include('../partials/head') %>
<section class="row justify-content-center">
  <div class="col-lg-5">
    <div class="card shadow-sm border-0">
      <div class="card-body p-4 p-md-5">
        <h1 class="h3 mb-3">Login</h1>
        <p class="text-muted">Access your travel journals.</p>
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-danger"><%= error %></div>
        <% } %>
        <form class="needs-validation" action="/login" method="POST" novalidate>
          <div class="mb-3">
            <label for="username" class="form-label">Username</label>
            <input type="text" class="form-control" id="username" name="username" value="<%= formData.username || '' %>" required minlength="3" />
            <div class="invalid-feedback">Username is required.</div>
          </div>
          <div class="mb-3">
            <label for="password" class="form-label">Password</label>
            <input type="password" class="form-control" id="password" name="password" required minlength="6" />
            <div class="invalid-feedback">Password is required.</div>
          </div>
          <button class="btn btn-primary w-100" type="submit">Login</button>
        </form>
        <p class="mt-3 mb-0 text-center small">Need an account? <a href="/register">Register here</a></p>
      </div>
    </div>
  </div>
</section>
<%- include('../partials/footer') %>
